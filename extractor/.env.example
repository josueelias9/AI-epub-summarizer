# Environment configuration for EPUB Extractor

# EPUB Processing Configuration
# Required: Name of the EPUB file to process
EPUB_FILE=my_epub.epub

# Optional: Custom output filename (if not set, will auto-generate)
# OUTPUT_FILE=custom_structure.pdf

# Input directory path (where EPUB files are located)
INPUT_PATH=./

# Output directory path (where PDF will be saved)
OUTPUT_PATH=./output

# Database Configuration (PostgreSQL)
DB_HOST=db
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=epub_extractor

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true