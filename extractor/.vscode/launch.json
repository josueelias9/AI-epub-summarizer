{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API: FastAPI (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host", "0.0.0.0",
                "--port", "8000",
                "--reload"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "envFile": "${workspaceFolder}/.env",
            "jinja": true
        },
        {
            "name": "EPUB: process (mediator)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/application/services/epub_processing_service.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${command:python.interpreterPath}",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}