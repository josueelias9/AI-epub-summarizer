{
  "name": "Extractor Container",
  "dockerComposeFile": ["../../docker-compose.yml","../../docker-compose.extractor.yml"],
  "service": "extractor",
  "shutdownAction": "none",
  "workspaceFolder": "/workspace/extractor",
  "customizations": {
    "vscode": {
      "extensions": [
        "hediet.vscode-drawio",
        "ms-python.python",
        "tomoki1207.pdf",
        "marp-team.marp-vscode",
        "humao.rest-client",
        "Gruntfuggly.todo-tree",
        "bierner.markdown-mermaid"
      ],
      "settings": {
        "workbench.colorTheme": "Tomorrow Night Blue"
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers-extra/features/curl-apt-get:1": {}
  },
  "runServices": ["extractor"]

}
